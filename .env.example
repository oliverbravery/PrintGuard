# PrintGuard Environment Configuration
# Copy this file to .env and fill in your values

# VAPID Keys for Web Push Notifications
# Generate with: printguard generate-keys --env
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# Application Settings
DEBUG=false
HOST=0.0.0.0
PORT=8000
MODEL_DIR="./model"

# Tunnel Settings
# Options: local, cloudflare, ngrok
TUNNEL_PROVIDER="local"

# Cloudflare Tunnel Settings
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_DOMAIN=""
CLOUDFLARE_TUNNEL_NAME="printguard-tunnel"
CLOUDFLARE_SUBDOMAIN="printguard"

# ngrok Settings
NGROK_AUTHTOKEN=""
NGROK_DOMAIN=""
NGROK_EDGE=""
